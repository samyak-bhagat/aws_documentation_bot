# Copy to terraform.tfvars and adjust as needed.
# NEVER commit terraform.tfvars if it contains secrets.

project_name  = "aws-docs-bot"
environment   = "dev"
aws_region    = "us-east-1"

vpc_cidr           = "10.0.0.0/16"
az_count           = 2
enable_nat_gateway = false

db_name            = "aws_docs"
rds_instance_class = "db.t4g.micro"

opensearch_instance_type  = "t3.small.search"
opensearch_instance_count = 1

bedrock_model_id       = "us.anthropic.claude-sonnet-4-5-20250929-v1:0"
bedrock_embed_model_id = "amazon.titan-embed-text-v2:0"

image_tag = "latest"

# Route 53 — leave empty until you have a hosted zone
route53_zone_id = ""
domain_name     = ""

# GitHub OIDC deploy role (enable after first manual deploy works)
enable_github_oidc = true
github_repo        = "samyak-bhagat/aws_documentation_bot"

ecr_force_delete = true
