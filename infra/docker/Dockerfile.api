# Phase 4 — minimal API image
FROM python:3.12-slim

WORKDIR /app

# Install uv so uvx can launch the AWS Docs MCP Server at runtime
RUN pip install --no-cache-dir uv

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Ensure the MCP server binary is pre-cached by uvx at build time
RUN uvx awslabs.aws-documentation-mcp-server@latest --help 2>/dev/null || true

EXPOSE 8000

CMD ["uvicorn", "apps.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
